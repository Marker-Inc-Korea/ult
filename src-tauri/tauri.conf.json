{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ult",
  "version": "0.1.0",
  "identifier": "engineer.ultra.ult",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "palette",
        "title": "Ult Palette",
        "width": 800,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "focusable": false
      },
      {
        "label": "settings",
        "title": "Preferences",
        "width": 1000,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "copyright": "Copyright © 2026 Ult contributors",
    "category": "DeveloperTool"
  }
}
